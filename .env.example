# Agency-Kit — environment variables
# Copy this file to .env and fill in your values.

# ── Model tiers ────────────────────────────────────────────────────────────────
# Elite tier: meta-commander, inspector, cross-department synthesis
AK_ELITE_MODEL=claude-opus-4-8

# Standard tier: router, lightweight structured tasks
AK_STANDARD_MODEL=claude-sonnet-4-6

# ── Provider ───────────────────────────────────────────────────────────────────
# Anthropic (default)
ANTHROPIC_API_KEY=your-anthropic-key-here

# OpenAI (if using OpenAI models)
# OPENAI_API_KEY=your-openai-key-here

# Gemini via OpenAI-compatible endpoint
# OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# OPENAI_API_KEY=your-gemini-key-here
# AK_ELITE_MODEL=gemini-2.5-pro
# AK_STANDARD_MODEL=gemini-2.5-flash

# ── Search backend ─────────────────────────────────────────────────────────────
# ddg (DuckDuckGo, no key needed) | tavily | gemini | openai
AK_SEARCH=ddg
# TAVILY_API_KEY=your-tavily-key-here   # required when AK_SEARCH=tavily

# ── Department kit overrides (optional) ────────────────────────────────────────
# Each installed kit reads its own vars; AK_* are agency-level only.
# PK_ELITE_MODEL=claude-opus-4-8        # product-kit
# PK_STANDARD_MODEL=claude-sonnet-4-6
# MK_ELITE_MODEL=claude-opus-4-8        # marketing-kit
# MK_STANDARD_MODEL=claude-sonnet-4-6
